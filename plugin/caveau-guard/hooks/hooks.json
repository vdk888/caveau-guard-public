{
  "description": "Caveau guard — block reads of protected client folders until anonymised; tripwire raw PII pasted/uploaded into the chat. SessionStart self-installs the guard into the Cowork VM's user settings so it fires there; the installer is GATED to the Cowork sandbox (HOME=/sessions/* or CLAUDE_CODE_IS_COWORK) and no-ops on the host machine, so it can never spill onto a real Mac.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/install_user_hooks.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Glob|Grep|Bash|NotebookEdit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/guard.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/tripwire.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Bash|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"${CLAUDE_PLUGIN_ROOT}/scripts/posttool_anonymize.py\" ] && python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/posttool_anonymize.py\" || exit 0"
          }
        ]
      }
    ]
  }
}
